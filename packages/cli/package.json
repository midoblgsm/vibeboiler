{
  "name": "@vibeboiler/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Setup wizard for the vibeboiler monorepo template",
  "type": "module",
  "bin": {
    "vibeboiler": "./dist/index.js"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node ./dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.0",
    "execa": "^9.5.0",
    "jose": "^5.9.0",
    "libsodium-wrappers": "0.7.15",
    "ora": "^8.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.10.0",
    "msw": "^2.7.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}

# Firebase Configuration (Web)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Configuration (Mobile - used in app.json or EAS secrets)
FIREBASE_API_KEY=your-api-key

# Neon Postgres (used by Firebase Functions)
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Firebase Admin (Functions runtime)
# These are auto-configured when deployed to Firebase Functions
# For local development, set GOOGLE_APPLICATION_CREDENTIALS to your service account key path
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# Expo
EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
